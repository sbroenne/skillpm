{
  "name": "skillpm",
  "version": "0.0.1",
  "description": "npm for Agent Skills",
  "type": "module",
  "bin": {
    "skillpm": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "format": "prettier --write 'src/**/*.ts'",
    "prepublishOnly": "npm run lint && npm run build && npm test"
  },
  "files": [
    "dist",
    "!dist/**/*.test.*",
    "!dist/**/*.map",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "agent-skills",
    "skills",
    "ai-agents",
    "cli",
    "npm"
  ],
  "homepage": "https://skillpm.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sbroenne/skillpm.git"
  },
  "bugs": {
    "url": "https://github.com/sbroenne/skillpm/issues"
  },
  "author": "sbroenne",
  "license": "MIT",
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "gray-matter": "^4.0.3",
    "picocolors": "^1.1.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.3.0",
    "eslint": "^10.0.2",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.0.18"
  }
}
